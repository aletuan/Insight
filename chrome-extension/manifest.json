{
  "manifest_version": 3,
  "name": "Insight — Bookmark Capture",
  "version": "1.0.0",
  "description": "Automatically sends new Chrome bookmarks to your Insight digest API.",
  "permissions": [
    "bookmarks",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
